# ── Claude (필수) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── Supertonic-3 TTS (로컬 서버) ────────────────────────────────────────────
# supertonic serve 로 서버 실행 후 사용 (기본 포트: 7788)
# 포트를 바꾸지 않는 한 수정 불필요
SUPERTONIC_TTS_URL=http://localhost:7788

# ── 접근 제어 (외부 공개 시 설정, 로컬 개발 시 주석 처리) ────────────────────
# ACCESS_PASSWORD: 사용자가 입력할 비밀번호
# ACCESS_TOKEN: 서버가 발급할 세션 토큰 (랜덤 문자열, 절대 공유 금지)
# 두 값 모두 설정해야 인증이 활성화됩니다.
# ACCESS_PASSWORD=your-password-here
# ACCESS_TOKEN=change-this-to-a-random-40-char-string

# ── 생성 횟수 제한 (선택) ────────────────────────────────────────────────────
# IP당 하루 최대 생성 횟수. 0 또는 미설정 시 무제한.
# DAILY_GENERATION_LIMIT=10
