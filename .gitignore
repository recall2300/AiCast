# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — .local 파일에 실제 키가 있으므로 절대 커밋하지 않음
.env*
# example 파일은 플레이스홀더만 담으므로 커밋 허용
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python virtual environments
**/.venv/
**/venv/
**/__pycache__/
*.pyc

# claude settings (local only)
.claude/
